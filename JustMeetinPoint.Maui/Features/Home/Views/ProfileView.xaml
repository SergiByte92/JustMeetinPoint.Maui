<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.ProfileView"
    Title="Perfil"
    BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="12,12,12,24">

            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E8EAED"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border
                            WidthRequest="58"
                            HeightRequest="58"
                            BackgroundColor="#1A73E8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 29">

                            <Label
                                Text="{Binding UserInitials}"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label
                                Text="{Binding FullName}"
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="#202124" />

                            <Label
                                Text="{Binding Email}"
                                FontSize="12"
                                TextColor="#5F6368" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border
                        BackgroundColor="#F8F9FA"
                        Stroke="#E8EAED"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="14,12">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Text="👤" FontSize="16" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Datos personales" FontSize="13" FontAttributes="Bold" TextColor="#202124" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#9AA0A6" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E8EAED"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Estadísticas del usuario"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Resumen visual de tu actividad dentro de JMP."
                            FontSize="12"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <Border
                        BackgroundColor="#F8F9FA"
                        Stroke="#E8EAED"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="12"
                        HeightRequest="220">

                        <Grid HeightRequest="190">
                            <Border
                                BackgroundColor="#1A73E8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="120"
                                WidthRequest="28"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="12,0,0,0" />

                            <Border
                                BackgroundColor="#34A853"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="160"
                                WidthRequest="28"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="56,0,0,0" />

                            <Border
                                BackgroundColor="#FBBC04"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="90"
                                WidthRequest="28"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="100,0,0,0" />

                            <Border
                                BackgroundColor="#D94FA8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="175"
                                WidthRequest="28"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="144,0,0,0" />

                            <Label
                                Text="Gráfico placeholder"
                                FontSize="12"
                                TextColor="#5F6368"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,6,6,0" />
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#F8F9FA" Stroke="#E8EAED" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Quedadas creadas" FontSize="11" TextColor="#5F6368" />
                                <Label Text="{Binding MeetingsCreated}" FontSize="18" FontAttributes="Bold" TextColor="#202124" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#F8F9FA" Stroke="#E8EAED" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Grupos completados" FontSize="11" TextColor="#5F6368" />
                                <Label Text="{Binding CompletedGroups}" FontSize="18" FontAttributes="Bold" TextColor="#202124" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#F8F9FA" Stroke="#E8EAED" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Tiempo medio" FontSize="11" TextColor="#5F6368" />
                                <Label Text="{Binding AvgTravelTimeText}" FontSize="18" FontAttributes="Bold" TextColor="#202124" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#F8F9FA" Stroke="#E8EAED" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Última actividad" FontSize="11" TextColor="#5F6368" />
                                <Label Text="{Binding LastActivityText}" FontSize="16" FontAttributes="Bold" TextColor="#202124" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E8EAED"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="0">

                <VerticalStackLayout Spacing="0">
                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="🔔" FontSize="16" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Notificaciones" FontSize="13" TextColor="#202124" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#9AA0A6" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F1F3F4" />

                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="🔒" FontSize="16" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Privacidad" FontSize="13" TextColor="#202124" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#9AA0A6" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F1F3F4" />

                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="ℹ️" FontSize="16" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Acerca de JMP" FontSize="13" TextColor="#202124" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#9AA0A6" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#FCE8E6"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="0">

                <Grid Padding="16,14" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Label Text="🚪" FontSize="16" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Cerrar sesión" FontSize="13" FontAttributes="Bold" TextColor="#EA4335" VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>