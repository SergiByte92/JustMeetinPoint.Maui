<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetingPoint.Maui.Features.Home.Views.HomeView"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0B2545">

    <Grid Padding="24"
          RowDefinitions="Auto,Auto,*">

        <VerticalStackLayout Grid.Row="0"
                             Margin="0,30,0,20"
                             Spacing="6">

            <Label Text="HOME"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label Text="Pantalla principal de Just Meeting Point"
                   FontSize="16"
                   TextColor="#94A3B8" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                BackgroundColor="#102D53"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="18"
                Margin="0,0,0,18">

            <VerticalStackLayout Spacing="8">
                <Label Text="Bienvenido"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White" />

                <Label Text="Aquí mostraremos resumen de grupos, actividad reciente y acceso rápido al mapa."
                       FontSize="14"
                       TextColor="#B8C4D0" />
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="2"
                             Spacing="12">

            <Border BackgroundColor="#102D53"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Padding="16">
                <Label Text="• Próximamente: tus grupos activos"
                       TextColor="White"
                       FontSize="15" />
            </Border>

            <Border BackgroundColor="#102D53"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Padding="16">
                <Label Text="• Próximamente: punto de encuentro recomendado"
                       TextColor="White"
                       FontSize="15" />
            </Border>

            <Border BackgroundColor="#102D53"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Padding="16">
                <Label Text="• Próximamente: accesos rápidos"
                       TextColor="White"
                       FontSize="15" />
            </Border>

        </VerticalStackLayout>

    </Grid>
</ContentPage>