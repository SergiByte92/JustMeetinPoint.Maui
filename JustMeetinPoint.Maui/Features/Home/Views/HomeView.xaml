<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.HomeView"
    Title="Inicio"
    BackgroundColor="#F8F9FA">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- HERO SUPERIOR -->
            <Border
                BackgroundColor="#FFFFFF"
                StrokeThickness="0"
                Padding="20,18,20,18">

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Hola, Sergi 👋"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <Label
                        Text="¿Dónde quedamos hoy?"
                        FontSize="14"
                        TextColor="#5F6368" />
                </VerticalStackLayout>
            </Border>

            <!-- CTA PRINCIPAL -->
            <Border
                Margin="12,12,12,0"
                BackgroundColor="#1A73E8"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="18">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Organiza una nueva quedada"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF" />

                        <Label
                            Text="Crea un grupo, comparte el código y encuentra el punto más justo."
                            FontSize="12"
                            TextColor="#DCE8FF" />

                        <Button
                            Text="Crear grupo"
                            Margin="0,8,0,0"
                            WidthRequest="130"
                            HeightRequest="40"
                            BackgroundColor="#FFFFFF"
                            TextColor="#1A73E8"
                            FontAttributes="Bold"
                            CornerRadius="20"
                            HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <Label
                        Grid.Column="1"
                        Text="📍"
                        FontSize="34"
                        VerticalOptions="Center"
                        Opacity="0.45"
                        TextColor="#FFFFFF"
                        Margin="12,0,0,0" />
                </Grid>
            </Border>

            <!-- CABECERA SUGERENCIAS -->
            <Grid
                Padding="16,18,16,8"
                ColumnDefinitions="*,Auto">

                <Label
                    Text="Sugerencias para hoy"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="#202124" />

                <Label
                    Grid.Column="1"
                    Text="Ver más"
                    FontSize="12"
                    TextColor="#1A73E8"
                    VerticalOptions="End" />
            </Grid>

            <!-- CHIPS -->
            <ScrollView
                Orientation="Horizontal"
                Margin="12,0,0,0"
                HorizontalScrollBarVisibility="Never">

                <HorizontalStackLayout Spacing="8" Padding="0,0,12,0">

                    <Border
                        BackgroundColor="#E8F0FE"
                        Stroke="#1A73E8"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="🍕 Comer"
                            FontSize="12"
                            TextColor="#1A73E8"
                            FontAttributes="Bold" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#E8EAED"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="☕ Café"
                            FontSize="12"
                            TextColor="#202124" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#E8EAED"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="🎭 Ocio"
                            FontSize="12"
                            TextColor="#202124" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#E8EAED"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="🏃 Deporte"
                            FontSize="12"
                            TextColor="#202124" />
                    </Border>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- CARD 1 -->
            <Border
                Margin="12,12,12,0"
                BackgroundColor="#FFFFFF"
                Stroke="#E8EAED"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#E8F0FE"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                        <Label
                            Text="🍕"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            FontSize="18" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label
                            Text="Actividades para grupos pequeños"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Propuestas para encuentros rápidos"
                            FontSize="11"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- CARD 2 -->
            <Border
                Margin="12,8,12,20"
                BackgroundColor="#FFFFFF"
                Stroke="#E8EAED"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#E6F4EA"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                        <Label
                            Text="📍"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            FontSize="18" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label
                            Text="Sugerencia de punto final"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Más adelante sugerirá lugares cercanos al punto calculado"
                            FontSize="11"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>