<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.MapView"
    Title="Mapa"
    BackgroundColor="#0B2545">

    <Grid RowDefinitions="*,Auto">

        <WebView x:Name="MapWebView" Grid.Row="0" />

        <VerticalStackLayout Grid.Row="1"
                             Padding="20,16,20,20"
                             Spacing="6"
                             BackgroundColor="#0B2545">

            <Label Text="Punto de encuentro"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#EAEAEA" />

            <Label Text="{Binding Latitude, StringFormat='Latitud: {0:F6}'}"
                   TextColor="#BDBDBD" FontSize="14" />

            <Label Text="{Binding Longitude, StringFormat='Longitud: {0:F6}'}"
                   TextColor="#BDBDBD" FontSize="14" />

            <Label Text="{Binding DurationText, StringFormat='Duración estimada: {0}'}"
                   TextColor="#D94FA8"
                   FontSize="15"
                   FontAttributes="Bold" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>