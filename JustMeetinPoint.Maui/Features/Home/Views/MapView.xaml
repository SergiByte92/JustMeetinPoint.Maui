<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.MapView"
    Title="Mapa"
    BackgroundColor="#0B2545">

    <Grid RowDefinitions="*,Auto">
        <WebView x:Name="MapWebView"
                 Grid.Row="0" />

        <VerticalStackLayout Grid.Row="1"
                             Padding="20"
                             Spacing="8"
                             BackgroundColor="#0B2545">

            <Label Text="Mapa"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label Text="{Binding Latitude, StringFormat='Latitud: {0:F6}'}"
                   TextColor="White"
                   FontSize="16" />

            <Label Text="{Binding Longitude, StringFormat='Longitud: {0:F6}'}"
                   TextColor="White"
                   FontSize="16" />

            <Label Text="{Binding DurationSeconds, StringFormat='Duración: {0} segundos'}"
                   TextColor="White"
                   FontSize="16" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>