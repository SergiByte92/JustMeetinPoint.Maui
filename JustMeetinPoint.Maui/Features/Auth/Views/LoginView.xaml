<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Auth.Views.LoginView"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <Grid
            Padding="28"
            RowDefinitions="Auto,Auto">

            <!-- BRAND HEADER -->
            <VerticalStackLayout
                Grid.Row="0"
                Margin="0,48,0,28"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="14">

                <Image
                    Source="app_logo.svg"
                    WidthRequest="96"
                    HeightRequest="96"
                    Aspect="AspectFit" />

                <Label
                    Text="Just Meeting Point"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#0B2545"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Encuentra el punto justo para todos"
                    FontSize="15"
                    TextColor="#5F6368"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- LOGIN CARD -->
            <Border
                Grid.Row="1"
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="20">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Iniciar sesión"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Accede para continuar con tus quedadas."
                            FontSize="14"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <!-- EMAIL -->
                    <Border
                        Margin="0,8,0,0"
                        BackgroundColor="#F8F9FA"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Correo electrónico"
                            Text="{Binding Email}"
                            Keyboard="Email"
                            TextColor="#202124"
                            PlaceholderColor="#98A2B3"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- PASSWORD -->
                    <Border
                        BackgroundColor="#F8F9FA"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Contraseña"
                            Text="{Binding Password}"
                            IsPassword="True"
                            TextColor="#202124"
                            PlaceholderColor="#98A2B3"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- MESSAGE -->
                    <Label
                        Text="{Binding Message}"
                        TextColor="#D93025"
                        FontSize="13"
                        LineBreakMode="WordWrap" />

                    <!-- PRIMARY CTA -->
                    <Button
                        Text="Iniciar sesión"
                        Margin="0,8,0,0"
                        HeightRequest="52"
                        BackgroundColor="#0B2545"
                        TextColor="#FFFFFF"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Command="{Binding LoginCommand}" />

                    <!-- SECONDARY CTA -->
                    <Button
                        Text="Crear cuenta"
                        HeightRequest="52"
                        BackgroundColor="#FFFFFF"
                        TextColor="#1A73E8"
                        BorderColor="#E5E7EB"
                        BorderWidth="1"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Command="{Binding GoToRegisterCommand}" />

                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>
</ContentPage>